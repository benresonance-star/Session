{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/fitness-session.schema.json",
  "title": "Fitness Session Definition",
  "description": "Canonical schema for defining workout sessions used by import, builder, and play modes.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "session_id", "title", "stages"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.1" },
    "session_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": { "type": "string", "minLength": 1, "maxLength": 120 },
    "description": { "type": "string", "maxLength": 2000 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1, "maxLength": 40 },
      "uniqueItems": true,
      "maxItems": 20,
      "default": []
    },
    "duration_minutes": { "type": "integer", "minimum": 1, "maximum": 300 },
    "notes": { "type": "string", "maxLength": 4000 },
    "stages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/stage" }
    }
  },
  "$defs": {
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_id", "title"],
      "properties": {
        "stage_id": { "type": "string", "enum": ["warmup", "main", "cooldown"] },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "notes": { "type": "string", "maxLength": 2000 },
        "sections": {
          "type": "array",
          "minItems": 1,
          "maxItems": 30,
          "items": { "$ref": "#/$defs/section" }
        },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/$defs/block" }
        }
      },
      "anyOf": [
        { "required": ["sections"] },
        { "required": ["blocks"] }
      ]
    },
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section_id", "title", "blocks"],
      "properties": {
        "section_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "notes": { "type": "string", "maxLength": 2000 },
        "rest_after_section_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 },
        "blocks": {
          "type": "array",
          "minItems": 1,
          "maxItems": 30,
          "items": { "$ref": "#/$defs/block" }
        }
      }
    },
    "block": {
      "oneOf": [
        { "$ref": "#/$defs/block_flow" },
        { "$ref": "#/$defs/block_straight_sets" },
        { "$ref": "#/$defs/block_circuit_rounds" },
        { "$ref": "#/$defs/block_circuit_time" },
        { "$ref": "#/$defs/block_superset" },
        { "$ref": "#/$defs/block_emom" }
      ]
    },
    "block_base": {
      "type": "object",
      "additionalProperties": false,
      "required": ["block_id", "block_type", "title"],
      "properties": {
        "block_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "block_type": {
          "type": "string",
          "enum": ["flow", "straight_sets", "circuit_rounds", "circuit_time", "superset", "emom"]
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "notes": { "type": "string", "maxLength": 2000 }
      }
    },
    "block_flow": {
      "allOf": [
        { "$ref": "#/$defs/block_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["block_id", "block_type", "title", "exercises"],
          "properties": {
            "block_id": { "type": "string" },
            "block_type": { "const": "flow" },
            "title": { "type": "string" },
            "notes": { "type": "string" },
            "rounds": { "type": "integer", "minimum": 1, "maximum": 20, "default": 1 },
            "time_cap_seconds": { "type": "integer", "minimum": 1, "maximum": 10800 },
            "rest_between_rounds_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 },
            "exercises": {
              "type": "array",
              "minItems": 1,
              "maxItems": 50,
              "items": { "$ref": "#/$defs/exercise" }
            }
          }
        }
      ]
    },
    "block_straight_sets": {
      "allOf": [
        { "$ref": "#/$defs/block_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["block_id", "block_type", "title", "sets", "exercises"],
          "properties": {
            "block_id": { "type": "string" },
            "block_type": { "const": "straight_sets" },
            "title": { "type": "string" },
            "notes": { "type": "string" },
            "sets": { "type": "integer", "minimum": 1, "maximum": 20 },
            "rest_between_sets_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 },
            "exercises": {
              "type": "array",
              "minItems": 1,
              "maxItems": 50,
              "items": { "$ref": "#/$defs/exercise" }
            }
          }
        }
      ]
    },
    "block_circuit_rounds": {
      "allOf": [
        { "$ref": "#/$defs/block_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["block_id", "block_type", "title", "rounds", "exercises"],
          "properties": {
            "block_id": { "type": "string" },
            "block_type": { "const": "circuit_rounds" },
            "title": { "type": "string" },
            "notes": { "type": "string" },
            "rounds": { "type": "integer", "minimum": 1, "maximum": 50 },
            "rest_between_rounds_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 },
            "exercises": {
              "type": "array",
              "minItems": 1,
              "maxItems": 50,
              "items": { "$ref": "#/$defs/exercise" }
            }
          }
        }
      ]
    },
    "block_circuit_time": {
      "allOf": [
        { "$ref": "#/$defs/block_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["block_id", "block_type", "title", "duration_seconds", "exercises"],
          "properties": {
            "block_id": { "type": "string" },
            "block_type": { "const": "circuit_time" },
            "title": { "type": "string" },
            "notes": { "type": "string" },
            "duration_seconds": { "type": "integer", "minimum": 1, "maximum": 10800 },
            "rest_as_needed": { "type": "boolean", "default": true },
            "exercises": {
              "type": "array",
              "minItems": 1,
              "maxItems": 50,
              "items": { "$ref": "#/$defs/exercise" }
            }
          }
        }
      ]
    },
    "block_superset": {
      "allOf": [
        { "$ref": "#/$defs/block_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["block_id", "block_type", "title", "sets", "exercise_pairs"],
          "properties": {
            "block_id": { "type": "string" },
            "block_type": { "const": "superset" },
            "title": { "type": "string" },
            "notes": { "type": "string" },
            "sets": { "type": "integer", "minimum": 1, "maximum": 20 },
            "rest_between_sets_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 },
            "exercise_pairs": {
              "type": "array",
              "minItems": 1,
              "maxItems": 20,
              "items": {
                "type": "array",
                "minItems": 2,
                "maxItems": 2,
                "items": { "$ref": "#/$defs/exercise" }
              }
            }
          }
        }
      ]
    },
    "block_emom": {
      "allOf": [
        { "$ref": "#/$defs/block_base" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["block_id", "block_type", "title", "minutes", "exercises"],
          "properties": {
            "block_id": { "type": "string" },
            "block_type": { "const": "emom" },
            "title": { "type": "string" },
            "notes": { "type": "string" },
            "minutes": { "type": "integer", "minimum": 1, "maximum": 180 },
            "exercises": {
              "type": "array",
              "minItems": 1,
              "maxItems": 10,
              "items": { "$ref": "#/$defs/exercise" }
            }
          }
        }
      ]
    },
    "exercise": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exercise_id", "title", "equipment", "prescription"],
      "properties": {
        "exercise_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120,
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 120 },
        "movement_type": {
          "type": "string",
          "enum": ["strength", "conditioning", "mobility", "patterning", "breathing", "recovery", "other"],
          "default": "other"
        },
        "equipment": { "$ref": "#/$defs/equipment" },
        "prescription": { "$ref": "#/$defs/prescription" },
        "rest_after_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 },
        "cluster": {
          "type": "object",
          "additionalProperties": false,
          "required": ["reps_per_cluster", "clusters", "rest_between_clusters_seconds"],
          "properties": {
            "reps_per_cluster": { "type": "integer", "minimum": 1, "maximum": 100 },
            "clusters": { "type": "integer", "minimum": 1, "maximum": 100 },
            "rest_between_clusters_seconds": { "type": "integer", "minimum": 0, "maximum": 3600 }
          }
        },
        "tempo": { "type": "string", "maxLength": 40 },
        "sides": { "type": "string", "enum": ["both", "left", "right", "per_side"] },
        "notes": { "type": "string", "maxLength": 2000 },
        "link": { "$ref": "#/$defs/link" }
      }
    },
    "equipment": {
      "oneOf": [
        { "$ref": "#/$defs/equipment_bodyweight" },
        { "$ref": "#/$defs/equipment_kettlebell" },
        { "$ref": "#/$defs/equipment_band" },
        { "$ref": "#/$defs/equipment_dumbbell" },
        { "$ref": "#/$defs/equipment_barbell" },
        { "$ref": "#/$defs/equipment_machine" },
        { "$ref": "#/$defs/equipment_other" }
      ]
    },
    "equipment_bodyweight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": { "kind": { "const": "bodyweight" } }
    },
    "equipment_kettlebell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "load"],
      "properties": {
        "kind": { "const": "kettlebell" },
        "load": { "$ref": "#/$defs/load" }
      }
    },
    "equipment_band": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "band"],
      "properties": {
        "kind": { "const": "resistance_band" },
        "band": {
          "type": "object",
          "additionalProperties": false,
          "required": ["color", "style"],
          "properties": {
            "color": { "type": "string", "minLength": 1, "maxLength": 40 },
            "style": { "type": "string", "enum": ["loop", "flat", "tube", "mini", "other"] },
            "brand": { "type": "string", "maxLength": 80 }
          }
        }
      }
    },
    "equipment_dumbbell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "load"],
      "properties": {
        "kind": { "const": "dumbbell" },
        "load": { "$ref": "#/$defs/load" }
      }
    },
    "equipment_barbell": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "load"],
      "properties": {
        "kind": { "const": "barbell" },
        "load": { "$ref": "#/$defs/load" }
      }
    },
    "equipment_machine": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "const": "machine" },
        "machine_name": { "type": "string", "minLength": 1, "maxLength": 120 },
        "load": { "$ref": "#/$defs/load" }
      }
    },
    "equipment_other": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "label"],
      "properties": {
        "kind": { "const": "other" },
        "label": { "type": "string", "minLength": 1, "maxLength": 120 }
      }
    },
    "load": {
      "type": "object",
      "additionalProperties": false,
      "required": ["unit", "value"],
      "properties": {
        "unit": { "type": "string", "enum": ["kg", "lb"] },
        "value": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "prescription": {
      "oneOf": [
        { "$ref": "#/$defs/prescription_reps" },
        { "$ref": "#/$defs/prescription_rep_range" },
        { "$ref": "#/$defs/prescription_time" }
      ]
    },
    "prescription_reps": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "reps"],
      "properties": {
        "mode": { "const": "reps" },
        "reps": { "type": "integer", "minimum": 1, "maximum": 1000 }
      }
    },
    "prescription_rep_range": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "min_reps", "max_reps"],
      "properties": {
        "mode": { "const": "rep_range" },
        "min_reps": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "max_reps": { "type": "integer", "minimum": 1, "maximum": 1000 }
      }
    },
    "prescription_time": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "seconds"],
      "properties": {
        "mode": { "const": "time" },
        "seconds": { "type": "integer", "minimum": 1, "maximum": 10800 }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url"],
      "properties": {
        "label": { "type": "string", "maxLength": 80 },
        "url": { "type": "string", "format": "uri", "maxLength": 2000 }
      }
    }
  }
}
